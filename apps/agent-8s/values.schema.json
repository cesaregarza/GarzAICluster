{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "description": "Optional tag fallback when a digest is not provided."
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Preferred pinned digest."
        }
      },
      "required": ["repository"],
      "allOf": [
        {
          "anyOf": [
            { "required": ["digest"] },
            { "required": ["tag"] }
          ]
        }
      ],
      "additionalProperties": true
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        },
        "required": ["name"],
        "additionalProperties": false
      }
    },
    "secretRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      },
      "minItems": 1
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1 },
        "portName": { "type": "string" },
        "livenessPath": { "type": "string" },
        "readinessPath": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1 },
        "portName": { "type": "string" },
        "path": { "type": "string" },
        "service": { "type": "object" },
        "serviceMonitor": { "type": "object" }
      }
    },
    "hpa": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    }
  },
  "required": ["image", "secretRefs"],
  "additionalProperties": true
}
